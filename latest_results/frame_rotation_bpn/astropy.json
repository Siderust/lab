  "description": {
    "title": "Frame Rotation (Bias-Precession-Nutation)",
    "what": "Rotates a direction vector from the ICRS celestial reference frame to the True-of-Date frame using the Bias-Precession-Nutation (BPN) matrix.",
    "why": "This is the fundamental coordinate transformation used in astrometry. Differences indicate how well each library models Earth's axis wobble.",
    "units": "Angular error in milli-arcseconds (mas). 1 mas = 1/3,600,000 of a degree.",
    "interpret": "Lower error = closer to ERFA's IAU 2006/2000A model. Siderust uses simpler Meeus precession + IAU 1980 nutation, so some offset is expected."
  },
